{
  "name": "@devmahmoudi/auth",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "concurrently \"tsc -p tsconfig.build.json --watch\" \"vite\"",
    "build": "tsc -p tsconfig.build.json && tailwindcss -i ./src/index.css -o ./dist/styles.css",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@devmahmoudi/ui": "workspace:*",
    "@supabase/supabase-js": "^2.110.0",
    "@tailwindcss/vite": "^4.3.1",
    "concurrently": "^10.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.1.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}